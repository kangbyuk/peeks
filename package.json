{
  "name": "peeks",
  "version": "1.0.1",
  "description": "PEEKS — always-on-top sports widget built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "publish": null,
    "appId": "com.peeks.app",
    "productName": "PEEKS",
    "copyright": "Copyright © 2026",
    "directories": {
      "buildResources": "electron-resources",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/.bin/**",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,README,LICENSE,LICENSE.md,license,License}",
      "!node_modules/**/{test,tests,__tests__,example,examples,demo,benchmark}/**",
      "!node_modules/**/*.map",
      "!README.md",
      "!current_status.txt",
      "!dist/**",
      "!build/**/*.md",
      "!**/.git/**",
      "!**/*.iml",
      "!**/._*"
    ],
    "mac": {
      "category": "public.app-category.sports",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "PEEKS",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0"
  }
}
