{
  "name": "peeks",
  "version": "1.2.2",
  "description": "PEEKS — always-on-top sports widget built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE ./node_modules/.bin/electron .",
    "dev": "env -u ELECTRON_RUN_AS_NODE ./node_modules/.bin/electron .",
    "clean": "rm -rf \"$HOME/Library/Caches/Electron\" \"$HOME/Library/Caches/electron\" \"$HOME/Library/Caches/PEEKS\" \"$HOME/Library/Caches/com.peeks.app\" \"$HOME/Library/Application Support/PEEKS/Cache\" \"$HOME/Library/Application Support/PEEKS/Code Cache\" \"$HOME/Library/Application Support/PEEKS/GPUCache\" \"$HOME/Library/Application Support/PEEKS/DawnCache\" \"$HOME/Library/Application Support/PEEKS/DawnWebGPUCache\" && echo \"캐시 정리 완료. PEEKS를 완전히 종료한 뒤 npm start 하세요.\"",
    "icons:win": "node scripts/generate-win-ico.mjs",
    "prebuild": "npm run icons:win",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "release:upload": "gh release upload v1.2.2 \"dist/PEEKS-1.2.2-universal.dmg\" \"dist/PEEKS-Setup-1.2.2.exe\" --clobber",
    "release:publish": "bash scripts/publish-github-release.sh"
  },
  "build": {
    "publish": null,
    "appId": "com.peeks.app",
    "productName": "PEEKS",
    "copyright": "Copyright © 2026",
    "directories": {
      "buildResources": "electron-resources",
      "output": "dist"
    },
    "files": [
      "main.js",
      "ga4-mp.js",
      "ga4-secret.local.json.example",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/.bin/**",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,README,LICENSE,LICENSE.md,license,License}",
      "!node_modules/**/{test,tests,__tests__,example,examples,demo,benchmark}/**",
      "!node_modules/**/*.map",
      "!README.md",
      "!current_status.txt",
      "!dist/**",
      "!build/**/*.md",
      "!**/.git/**",
      "!**/*.iml",
      "!**/._*"
    ],
    "mac": {
      "category": "public.app-category.sports",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "PEEKS",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "PEEKS-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0"
  }
}
